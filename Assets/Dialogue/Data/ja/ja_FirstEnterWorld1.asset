  lines:
  - text: "\u3053\u3093\u306B\u3061\u306F\u3001\u3072\u3068\u3002"
    options:
    - "\u3053\u3093\u306B\u3061\u306F\u3001\u30BF\u30B3\u3055\u3093\u3002"
    - "\u308F\u3063\u3001\u3057\u3083\u3079\u308C\u308B\u3088\u3046\u306B\u306A\u3063\u305F\u3093\u3060\u3002"
  - text: "<anim:wave><color=red>\u308C\u3044\u3061</color></anim>\u3001\u306E\u304A\u304B\u3052\u3002"
    options:
    - "\u970A\u77E5\uFF1F"
  - text: "\u3072\u304B\u3063\u3066\u308B\u3001\u308C\u3044\u3061\u3002"
    options:
    - "\u3072\u304B\u3063\u3066\u308B\u306E\u304C\u970A\u77E5\uFF1F"
  - text: "\u3082\u3063\u3068\u3001\u307B\u3057\u3044\u3002"
    options:
    - "\u6B32\u5F35\u308A\u306A\u30BF\u30B3\u3060\u306A\u3042\u2026\u2026"
    - "\u524D\u306E\u7BB1\u306F\uFF1F"
  - text: "<anim:wave><color=red>\u308C\u3044\u3061</color></anim>\u3042\u308B\u305B\u304B\u3044\u3001<anim:wave><color=red>\u30D5\u30ED\u30FC</color></anim>\u3057\u3066\u308B\u3002"
    options:
    - "\u3058\u3083\u3042\u884C\u3053\u3046\u304B\u3002"
  - text: "\u306F\u3044\u308A\u304B\u305F\u3001\u308F\u304B\u3089\u306A\u3044\u2026\u2026"
    options:
    - "\u305D\u3046\u3044\u3046\u6642\u306F\u306D\u2026\u2026"
    - "\u8FD1\u3065\u3044\u3066E\u3092\u62BC\u3059\u3093\u3060\u3088\u3002"
